<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AR Viewer</title>
  <script src="https://aframe.io/releases/1.4.2/aframe.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/mind-ar@1.2.5/dist/mindar-image-aframe.prod.js"></script>
  <!-- aframe-extras needed for animation-mixer -->
  <script src="https://cdn.jsdelivr.net/npm/aframe-extras@7.2.0/dist/aframe-extras.min.js"></script>
  <style>
    body { margin: 0; }

    /* Hide all MindAR built-in UI */
    .mindar-ui-overlay, .mindar-ui-scanning, .mindar-ui-error, [class*="mindar"] { display: none !important; }

    #splash {
      position: fixed; inset: 0; z-index: 999;
      background: #08080f;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      font-family: sans-serif; color: white; text-align: center; padding: 32px;
    }
    #splash.gone { display: none; }
    #splash h1 { font-size: 28px; margin-bottom: 12px; }
    #splash p  { font-size: 14px; color: #888; margin-bottom: 40px; line-height: 1.6; }

    #startBtn {
      background: #00ffe0; color: #000;
      border: none; border-radius: 50px;
      padding: 16px 48px; font-size: 15px; font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>

<div id="splash">
  <h1>AR Image Viewer</h1>
  <p>Tap the button, allow camera access,<br>then point at the image.</p>
  <button id="startBtn" onclick="startAR()">Launch Camera</button>
</div>



<a-scene
  id="scene"
  mindar-image="imageTargetSrc: https://bonzomartini.github.io/ARRR/targets.mind;
    autoStart: false;
    uiLoading: no; uiError: no; uiScanning: no;
    filterMinCF: 0.001;
    filterBeta: 0.01;
    missTolerance: 1;
    warmupTolerance: 3;"
  color-space="sRGB"
  renderer="colorManagement: true; physicallyCorrectLights: true"
  vr-mode-ui="enabled: false"
  device-orientation-permission-ui="enabled: false"
>
  <a-assets>
    <a-asset-item id="model" src="https://bonzomartini.github.io/ARRR/BrunoAVTwithAnim.glb"></a-asset-item>
  </a-assets>

  <a-camera position="0 0 0" look-controls="enabled: false"></a-camera>

  <a-entity mindar-image-target="targetIndex: 0">
    <a-gltf-model
      id="myModel"
      src="#model"
      position="0 -0.5 0.1"
      scale="0.5 0.5 0.5"
    ></a-gltf-model>
  </a-entity>
</a-scene>

<script>
  // Start animation once model loads
  document.querySelector('#myModel').addEventListener('model-loaded', () => {
    const model = document.querySelector('#myModel');
    model.setAttribute('animation-mixer', 'loop: repeat; crossFadeDuration: 0.3;');
  });

  function startAR() {
    document.getElementById('splash').classList.add('gone');
    

    const scene = document.getElementById('scene');
    const sys = scene.systems['mindar-image-system'];
    sys.start();
  }
</script>

</body>
</html>
